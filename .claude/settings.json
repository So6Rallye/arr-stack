{
  "enabledPlugins": {
    "codex@openai-codex": true,
    "cc-gemini-plugin@cc-gemini-plugin": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "HOOK_DIR=\"$(cygpath -w \"$CLAUDE_PROJECT_DIR\" 2>/dev/null || echo \"$CLAUDE_PROJECT_DIR\")\" && node \"$HOOK_DIR\\.claude\\hooks\\pre-tool-use.mjs\" 2>>~/.claude/hooks-arrstack.log || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "HOOK_DIR=\"$(cygpath -w \"$CLAUDE_PROJECT_DIR\" 2>/dev/null || echo \"$CLAUDE_PROJECT_DIR\")\" && node \"$HOOK_DIR\\.claude\\hooks\\post-edit.mjs\" 2>>~/.claude/hooks-arrstack.log || true"
          }
        ]
      }
    ]
  }
}
