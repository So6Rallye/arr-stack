# Example environment values — copy to .env and adapt before first run

# Docker process user/group (run `id` to get your values)
PUID=1000
PGID=1000

# Timezone (TZ database name — https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=Europe/Paris

# Storage paths — must match actual mount points on the host
DATA_ROOT=/data
APPDATA_ROOT=/docker/appdata

# Backup base directory — created by install.sh, used by backup-arr-stack.sh
BACKUP_DEST=/backup

# Reference only — set via DHCP reservation on router (not injected into containers)
SERVER_IP=192.168.1.200

# Reference only — set via: sudo hostnamectl set-hostname arr-server (not injected into containers)
HOSTNAME=arr-server

# Gluetun / ProtonVPN WireGuard
VPN_SERVICE_PROVIDER=protonvpn
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=    # depuis dashboard ProtonVPN → WireGuard config
VPN_SERVER_COUNTRIES=Netherlands

# Immich database
IMMICH_DB_PASSWORD=
IMMICH_DB_USER=immich
IMMICH_DB_NAME=immich
